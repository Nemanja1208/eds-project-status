  "glossary": [
    {
      "term": "Freight forwarder",
      "definition": "Company that arranges transport of goods on behalf of customers. Doesn't own vehicles — contracts carriers. EDS is a freight forwarder.",
      "group": "Logistics Terms"
    },
    {
      "term": "Carrier",
      "definition": "Transport company that owns and operates vehicles (trucks, ships, planes).",
      "group": "Logistics Terms"
    },
    {
      "term": "Shipper / Customer",
      "definition": "The party that needs goods transported. Pays EDS.",
      "group": "Logistics Terms"
    },
    {
      "term": "Consignee",
      "definition": "The recipient of shipped goods at the destination.",
      "group": "Logistics Terms"
    },
    {
      "term": "Lane",
      "definition": "A specific origin→destination route (e.g., Stockholm→Hamburg).",
      "group": "Logistics Terms"
    },
    {
      "term": "Mode",
      "definition": "Transport type: Road, Air, or Sea.",
      "group": "Logistics Terms"
    },
    {
      "term": "Express freight",
      "definition": "Time-critical shipments where speed and reliability are premium.",
      "group": "Logistics Terms"
    },
    {
      "term": "LDM (Loading Meter)",
      "definition": "Standard unit for truck cargo space. 1 LDM = 1 meter of truck length × full width. Standard EU trailer = 13.6 LDM.",
      "group": "Logistics Terms"
    },
    {
      "term": "Pallet",
      "definition": "Standard cargo unit. EUR pallet = 120×80 cm, ISO pallet = 120×100 cm.",
      "group": "Logistics Terms"
    },
    {
      "term": "Co-loading",
      "definition": "Consolidating multiple shipments onto one vehicle. Currently 9% at EDS, target 25%+.",
      "group": "Logistics Terms"
    },
    {
      "term": "Linehaul",
      "definition": "The main trunk transport leg between major hubs (as opposed to first/last mile).",
      "group": "Logistics Terms"
    },
    {
      "term": "First-mile",
      "definition": "Pickup from customer/origin to the nearest hub.",
      "group": "Logistics Terms"
    },
    {
      "term": "Last-mile",
      "definition": "Delivery from hub to final destination.",
      "group": "Logistics Terms"
    },
    {
      "term": "ADR",
      "definition": "European agreement on dangerous goods transport. Some vehicles are ADR-certified.",
      "group": "Logistics Terms"
    },
    {
      "term": "Incoterms",
      "definition": "International trade terms defining buyer/seller responsibilities (e.g., DAP, DDP, FOB).",
      "group": "Logistics Terms"
    },
    {
      "term": "POD",
      "definition": "Proof of Delivery — document confirming goods were delivered.",
      "group": "Logistics Terms"
    },
    {
      "term": "BL (Bill of Lading)",
      "definition": "Document issued by sea carrier as receipt for goods.",
      "group": "Logistics Terms"
    },
    {
      "term": "AWB (Air Waybill)",
      "definition": "Document issued by air carrier as receipt for goods.",
      "group": "Logistics Terms"
    },
    {
      "term": "HS Code",
      "definition": "Harmonized System code — international product classification for customs.",
      "group": "Logistics Terms"
    },
    {
      "term": "EORI",
      "definition": "Economic Operators Registration and Identification number — required for EU customs.",
      "group": "Logistics Terms"
    },
    {
      "term": "TMS",
      "definition": "Transport Management System — software for managing logistics operations.",
      "group": "Logistics Terms"
    },
    {
      "term": "Curtain-sider",
      "definition": "Truck with flexible side curtains for easy loading/unloading (up to 5,000 kg).",
      "group": "Logistics Terms"
    },
    {
      "term": "Sprinter",
      "definition": "Small delivery van (up to 1,000 kg). Fastest option, most expensive per km.",
      "group": "Logistics Terms"
    },
    {
      "term": "RoN (Route of the North)",
      "definition": "EDS's contracted linehaul network. First route: Arlanda–Malmö–Hamburg.",
      "group": "EDS-specific Terms"
    },
    {
      "term": "Linehaul 1",
      "definition": "The first RoN route: ARN ↔ MMA ↔ HAM.",
      "group": "EDS-specific Terms"
    },
    {
      "term": "NB (Northbound)",
      "definition": "HAM → MMA → ARN direction. More profitable for co-loading (2.5-2.7x carrier cost vs SB).",
      "group": "EDS-specific Terms"
    },
    {
      "term": "SB (Southbound)",
      "definition": "ARN → MMA → HAM direction. Cheaper dedicated transport, tighter co-load economics.",
      "group": "EDS-specific Terms"
    },
    {
      "term": "EDS Search",
      "definition": "The platform's core rate-sourcing and comparison engine.",
      "group": "EDS-specific Terms"
    },
    {
      "term": "Email RFQ",
      "definition": "Request for Quotation sent to carriers via email (AI-assisted, human-gated).",
      "group": "EDS-specific Terms"
    },
    {
      "term": "Agreed Rates",
      "definition": "Pre-negotiated rates from carrier price lists, APIs, and Sendify marketplace.",
      "group": "EDS-specific Terms"
    },
    {
      "term": "PIPS",
      "definition": "Product Intelligence & Prioritization System — strategic feedback/analytics layer.",
      "group": "EDS-specific Terms"
    },
    {
      "term": "Rule of 40",
      "definition": "EDS's north star: growth rate + EBITDA margin ≥ 40%. Target: 20% + 20%.",
      "group": "EDS-specific Terms"
    },
    {
      "term": "GP1",
      "definition": "Gross Profit 1 = Revenue minus direct carrier cost.",
      "group": "EDS-specific Terms"
    },
    {
      "term": "Composite solution",
      "definition": "A multi-leg RoN solution: first-mile + linehaul + last-mile priced together.",
      "group": "EDS-specific Terms"
    },
    {
      "term": "Customer Saves",
      "definition": "Metric showing how much cheaper co-load is vs cheapest dedicated option.",
      "group": "EDS-specific Terms"
    },
    {
      "term": "Prioritise Speed toggle",
      "definition": "UI control that shifts ranking from cheapest to fastest option.",
      "group": "EDS-specific Terms"
    },
    {
      "term": "Gate",
      "definition": "Human approval checkpoint in the Email RFQ flow. Agent must approve before system acts.",
      "group": "EDS-specific Terms"
    },
    {
      "term": "Opter",
      "definition": "Road TMS — handles ~90% of EDS orders. Already live.",
      "group": "Systems"
    },
    {
      "term": "Logistaas",
      "definition": "Sea/Air TMS — being implemented at EDS.",
      "group": "Systems"
    },
    {
      "term": "Fortnox",
      "definition": "Swedish accounting software. Opter→Fortnox sync exists.",
      "group": "Systems"
    },
    {
      "term": "HubSpot",
      "definition": "CRM for sales pipeline, contacts. Being restructured.",
      "group": "Systems"
    },
    {
      "term": "Front",
      "definition": "Email/chat hub with shared inboxes. Current main comms tool.",
      "group": "Systems"
    },
    {
      "term": "Sendify",
      "definition": "Logistics marketplace with pricing API. Legacy system, shares ownership with EDS.",
      "group": "Systems"
    },
    {
      "term": "CloudTalk",
      "definition": "Cloud phone system replacing HubSpot calling.",
      "group": "Systems"
    },
    {
      "term": "Modjo",
      "definition": "AI call transcription/analysis connected to CloudTalk.",
      "group": "Systems"
    },
    {
      "term": "Rillion",
      "definition": "AP automation for supplier invoices. Independent, no integration needed.",
      "group": "Systems"
    }
  ],
