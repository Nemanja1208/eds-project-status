  "architecture": {
    "summary": "Hub-and-spoke model. The EDS Platform doesn't replace existing systems — it orchestrates them through one interface. Front (email), Opter (road TMS), Logistaas (sea/air TMS), Sendify (rates), Fortnox (invoicing), HubSpot (CRM) all flow into a single Go backend exposing EDS Search and a React workspace for agents.",
    "principles": [
      "Platform is the integration layer — agents make decisions, not integrations",
      "API-first — every feature is a REST endpoint before it gets a UI",
      "Vertical slices — each feature is UI-to-database complete",
      "Event-driven — state changes emit events (SQS → Kinesis)",
      "Human-gated AI — LLM accelerates, agent decides. Never auto-send.",
      "Multi-tenant RBAC — internal, customer, carrier users isolated by org_id"
    ],
    "dataModel": {
      "engine": "MySQL 8 (Aurora on AWS, Docker locally)",
      "tableCount": 8,
      "tables": [
        {
          "name": "webhook_events",
          "purpose": "Front.com webhook ingest log"
        },
        {
          "name": "inbound_requests",
          "purpose": "Parsed customer emails (LLM output)"
        },
        {
          "name": "booking_requests",
          "purpose": "Promoted bookings — full RFQ lifecycle"
        },
        {
          "name": "customers",
          "purpose": "69 seeded from Opter export"
        },
        {
          "name": "carriers",
          "purpose": "701 seeded from Opter export"
        },
        {
          "name": "carrier_quotes",
          "purpose": "Carrier responses to RFQ rounds"
        },
        {
          "name": "org_members",
          "purpose": "Multi-tenant RBAC + invites"
        },
        {
          "name": "rfq_rounds",
          "purpose": "Round-by-round RFQ history"
        }
      ],
      "moneyNote": "Money stored as int64 minor units (öre/cents). No floats."
    },
